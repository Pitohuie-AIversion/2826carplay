.bookings-page {
  padding: 24rpx 24rpx 48rpx;
  color: #ffffff;
  box-sizing: border-box;
  background: #101010;
}

.page-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  line-height: 1.35;
}

.loading {
  padding: 40rpx 0;
  color: rgba(255, 255, 255, 0.72);
}

.booking-item {
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.booking-main {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.booking-name {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.4;
  word-break: break-word;
}

.booking-status {
  max-width: 200rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.booking-sub {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
  line-height: 1.5;
}

.booking-date {
  max-width: 62%;
  word-break: break-word;
}

.booking-city {
  max-width: 34%;
  text-align: right;
  word-break: break-word;
}

.booking-note {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.6;
  word-break: break-word;
}

.booking-actions {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.booking-btn {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
  box-sizing: border-box;
}

.booking-btn-last {
  margin-right: 0;
}

.empty {
  padding: 70rpx 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.72);
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #ffffff;
  line-height: 1.35;
}

.empty-desc {
  font-size: 24rpx;
  margin-bottom: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.empty-action {
  box-sizing: border-box;
}
