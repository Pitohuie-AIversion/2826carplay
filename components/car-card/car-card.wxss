.car-card {
  position: relative;
  height: 400rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid #3a3a3a;
  border-radius: 16rpx;
  background: #181818;
  box-shadow: 0 14rpx 28rpx rgba(0, 0, 0, 0.24);
}

.car-cover {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1f1f1f, #0f0f0f);
}

.car-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 26rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.18), rgba(0, 0, 0, 0.64));
  box-sizing: border-box;
}

.car-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.car-nickname {
  max-width: 70%;
  color: #ffffff;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.1;
}

.car-status {
  margin-left: 16rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
}

.status-available {
  background: #2f80ed;
}

.status-rented {
  background: #8a8a8a;
}

.status-maintenance {
  background: #f2994a;
}

.status-reserved {
  background: #9b51e0;
}

.car-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.car-meta {
  flex: 1;
  min-width: 0;
}

.car-name {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.3;
}

.car-tags {
  margin-top: 12rpx;
  overflow: hidden;
}

.car-tag {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  color: #f2f2f2;
  font-size: 22rpx;
  line-height: 1;
  background: rgba(0, 0, 0, 0.22);
}

.car-price {
  flex-shrink: 0;
  margin-left: 20rpx;
  max-width: 240rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: right;
}
