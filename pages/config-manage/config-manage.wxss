.config-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #101010;
  box-sizing: border-box;
}

.hero-card,
.form-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-title,
.section-title,
.form-label {
  color: #ffffff;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-desc {
  margin-top: 10rpx;
  color: #b7b7b7;
  font-size: 24rpx;
  line-height: 1.7;
}

.form-tip {
  margin-top: 10rpx;
  color: #8f8f8f;
  font-size: 22rpx;
  line-height: 1.6;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
}

.form-item {
  margin-top: 20rpx;
}

.form-label {
  font-size: 24rpx;
  line-height: 1.6;
}

.form-input,
.form-textarea {
  width: 100%;
  margin-top: 12rpx;
  box-sizing: border-box;
}

.form-textarea {
  min-height: 140rpx;
}

.form-textarea-lg {
  min-height: 220rpx;
}

.action-row {
  display: flex;
}

.action-btn {
  flex: 1;
}

.action-btn-offset {
  margin-left: 16rpx;
}
