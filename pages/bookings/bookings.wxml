<view class="bookings-page">
  <view class="page-title">我的预约</view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{list.length}}">
    <view class="booking-item" wx:for="{{list}}" wx:key="id">
      <view class="booking-main">
        <view class="booking-name">{{item.vehicleName}}</view>
        <view class="booking-status">{{item.statusText}}</view>
      </view>
      <view class="booking-sub">
        <view class="booking-date">{{item.startDate}} - {{item.endDate}}</view>
        <view class="booking-city">{{item.city}}</view>
      </view>
      <view wx:if="{{item.note}}" class="booking-note">{{item.note}}</view>
    </view>
  </view>

  <view wx:else class="empty">
    <view class="empty-title">暂无预约</view>
    <view class="empty-desc">去车库挑一辆喜欢的车，提交预约咨询吧。</view>
    <button class="empty-action" bindtap="handleBackGarage">返回车库</button>
  </view>
</view>

