.bookings-page {
  padding: 24rpx 24rpx 48rpx;
  color: #ffffff;
  box-sizing: border-box;
}

.page-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.loading {
  padding: 40rpx 0;
  color: rgba(255, 255, 255, 0.72);
}

.booking-item {
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  margin-bottom: 18rpx;
}

.booking-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.booking-name {
  font-size: 30rpx;
  font-weight: 600;
}

.booking-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.booking-sub {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.72);
}

.booking-note {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.5;
}

.empty {
  padding: 70rpx 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.72);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #ffffff;
}

.empty-desc {
  font-size: 26rpx;
  margin-bottom: 28rpx;
}

.empty-action {
  background: #ffffff;
  color: #101010;
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 22rpx 0;
}

