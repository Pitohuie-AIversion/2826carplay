.detail-page {
  min-height: 100vh;
  padding-bottom: 196rpx;
  background: #101010;
}

.hero-swiper {
  height: 440rpx;
  background: #181818;
}

.hero-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1f1f1f, #0f0f0f);
}

.hero-placeholder {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 34rpx 28rpx;
  background: linear-gradient(135deg, #1b2c46, #0f1620);
  box-sizing: border-box;
}

.hero-placeholder-brand {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  line-height: 1.4;
}

.hero-placeholder-name {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-placeholder-text {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  line-height: 1.6;
}

.summary-card,
.notice-card,
.info-card,
.empty-page {
  margin: 24rpx;
  padding: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  background: #181818;
  box-sizing: border-box;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.12);
}

.summary-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.car-name {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.car-nickname {
  margin-top: 10rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.65;
}

.car-status {
  flex-shrink: 0;
  margin-left: 20rpx;
  max-width: 180rpx;
}

.car-price {
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.tag-list {
  margin-top: 20rpx;
}

.tag-item {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 18rpx;
  max-width: 100%;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 999rpx;
  color: #e6ebf2;
  font-size: 20rpx;
  line-height: 1.3;
  background: rgba(255, 255, 255, 0.05);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-card {
  border-color: rgba(47, 128, 237, 0.28);
  background: rgba(47, 128, 237, 0.08);
}

.notice-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
}

.notice-text {
  margin-top: 12rpx;
  color: #d8e6ff;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.section-text {
  margin-top: 16rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.7;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 22rpx;
}

.info-item {
  width: 48%;
  margin-bottom: 18rpx;
  padding: 24rpx 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.03);
}

.info-label {
  color: #8f98a6;
  font-size: 22rpx;
  line-height: 1.5;
}

.info-value {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.45;
  word-break: break-all;
}

.detail-bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #2a2a2a;
  background: rgba(16, 16, 16, 0.96);
  box-sizing: border-box;
}

.action-button {
  flex: 1;
  height: 88rpx;
  padding: 0 14rpx;
  font-size: 26rpx;
  line-height: 88rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-button-offset {
  margin-left: 16rpx;
}

.empty-action {
  height: 88rpx;
  margin-top: 24rpx;
  font-size: 26rpx;
  line-height: 88rpx;
}

.empty-page {
  margin-top: 48rpx;
  text-align: center;
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.4;
}

.empty-desc {
  margin-top: 16rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.6;
}
