.detail-page {
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  color: #ffffff;
  background: #101010;
}

.header-card,
.info-card,
.note-card {
  padding: 26rpx 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.booking-name {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.booking-status {
  display: inline-block;
  margin-top: 14rpx;
  max-width: 220rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 2rpx -6rpx 0;
}

.info-item {
  width: calc(50% - 12rpx);
  margin: 0 6rpx 12rpx;
  padding: 20rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
}

.info-item-full {
  width: calc(100% - 12rpx);
}

.info-label {
  font-size: 22rpx;
  color: #8f98a6;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.info-value {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
}

.note-title {
  font-size: 22rpx;
  color: #8f98a6;
  margin-bottom: 10rpx;
}

.note-content {
  font-size: 24rpx;
  line-height: 1.65;
  word-break: break-word;
}

.actions {
  margin-top: 10rpx;
}

.cancel-btn {
  width: 100%;
  box-sizing: border-box;
}
