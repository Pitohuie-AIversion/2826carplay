.vehicle-manage-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #101010;
  box-sizing: border-box;
}

.hero-card,
.dashboard-card,
.section-card,
.empty-card,
.vehicle-card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-title {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-desc,
.dashboard-desc,
.empty-desc,
.loading-text,
.meta-label,
.summary-label,
.result-count {
  color: #b7b7b7;
  font-size: 24rpx;
  line-height: 1.7;
}

.hero-button,
.search-button,
.reset-button {
  margin-top: 20rpx;
}

.reset-button {
  min-width: 180rpx;
  margin-top: 0;
}

.search-row,
.action-row,
.vehicle-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.search-input {
  flex: 1;
  box-sizing: border-box;
}

.search-button {
  width: 140rpx;
  margin-top: 0;
  margin-left: 16rpx;
}

.status-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.status-list {
  display: flex;
  align-items: center;
}

.status-item {
  margin-right: 16rpx;
  padding: 14rpx 24rpx;
  max-width: 220rpx;
  font-size: 24rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-row {
  margin-top: 20rpx;
}

.dashboard-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.dashboard-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.summary-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 0;
}

.summary-item {
  width: calc(33.3333% - 16rpx);
  margin-right: 24rpx;
  margin-bottom: 24rpx;
  padding: 28rpx 22rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
}

.summary-item:nth-child(3n) {
  margin-right: 0;
}

.summary-value {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.08;
}

.summary-label {
  margin-top: 10rpx;
  color: #9fa5b0;
  font-size: 22rpx;
  line-height: 1.5;
}

.ratio-card {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #2a2a2a;
}

.ratio-head {
  margin-bottom: 16rpx;
}

.ratio-bar {
  height: 18rpx;
  border-radius: 999rpx;
  background: #1a1a1a;
  overflow: hidden;
  display: flex;
}

.ratio-seg {
  height: 18rpx;
}

.ratio-idle {
  background: #27ae60;
}

.ratio-active {
  background: #2f80ed;
}

.ratio-maintenance {
  background: #f2994a;
}

.ratio-legend {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  width: 50%;
  margin-bottom: 12rpx;
}

.legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  margin-right: 10rpx;
}

.legend-text {
  color: #b7b7b7;
  font-size: 22rpx;
  line-height: 1.6;
}

.recent-block {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #2a2a2a;
}

.recent-head {
  margin-bottom: 16rpx;
}

.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #242424;
}

.recent-main {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.recent-plate {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
  word-break: break-all;
}

.recent-model {
  margin-top: 6rpx;
  color: #d6d6d6;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.recent-meta,
.recent-empty {
  margin-top: 8rpx;
  color: #a8a8a8;
  font-size: 22rpx;
  line-height: 1.6;
}

.loading-wrap,
.empty-card {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  text-align: center;
}

.vehicle-card-head {
  align-items: flex-start;
}

.vehicle-card-top {
  display: flex;
  align-items: flex-start;
}

.vehicle-cover-wrap {
  position: relative;
  width: 220rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.vehicle-cover {
  width: 220rpx;
  height: 164rpx;
  border-radius: 14rpx;
  background: #242424;
}

.vehicle-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1rpx dashed #444444;
  box-sizing: border-box;
}

.vehicle-cover-placeholder-text {
  color: #8e8e8e;
  font-size: 24rpx;
  line-height: 1.5;
}

.image-count-badge {
  position: absolute;
  right: 10rpx;
  bottom: 10rpx;
  padding: 8rpx 14rpx;
  max-width: 180rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.62);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vehicle-main {
  flex: 1;
  min-width: 0;
}

.plate-number {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
  word-break: break-all;
}

.brand-model {
  margin-top: 8rpx;
  color: #d1d1d1;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-word;
}

.vehicle-status {
  flex-shrink: 0;
  margin-left: 16rpx;
  max-width: 176rpx;
}

.vehicle-meta-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.meta-item {
  width: 50%;
  margin-bottom: 16rpx;
  padding-right: 16rpx;
  box-sizing: border-box;
}

.meta-value {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
}

.meta-value-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-action-row {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.status-op-card {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #141414;
  border: 1rpx solid #2b2b2b;
  box-sizing: border-box;
}

.status-op-title {
  color: #b7b7b7;
  font-size: 24rpx;
  line-height: 1.7;
}

.status-op-row {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.status-op-btn {
  min-width: 180rpx;
  height: 68rpx;
  margin: 0 16rpx 16rpx 0;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: #141414;
  color: #ffffff;
  padding: 0 16rpx;
  font-size: 24rpx;
  line-height: 68rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.status-op-btn-active {
  background: rgba(47, 128, 237, 0.22);
  border-color: rgba(47, 128, 237, 0.8);
}

.status-op-btn::after {
  border: 0;
}

.edit-button {
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.detail-button {
  min-width: 180rpx;
  height: 72rpx;
  margin: 0 0 16rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.retire-button {
  min-width: 180rpx;
  height: 72rpx;
  margin: 0 0 16rpx 16rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.restore-button {
  min-width: 180rpx;
  height: 72rpx;
  margin: 0 0 16rpx 16rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.delete-button {
  min-width: 180rpx;
  height: 72rpx;
  margin: 0 0 16rpx 16rpx;
  line-height: 72rpx;
  font-size: 24rpx;
}

.empty-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
}

.load-more {
  padding: 0;
  text-align: center;
}

.load-more-btn {
  width: 100%;
  margin: 0 0 24rpx;
}

.load-more-end {
  padding: 0 0 24rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8e8e8e;
}
