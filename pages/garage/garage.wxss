.garage-page {
  min-height: 100vh;
  padding: 48rpx 24rpx 196rpx;
  box-sizing: border-box;
  background: #101010;
}

.garage-header {
  padding: 8rpx 8rpx 16rpx;
}

.page-title {
  font-size: 36rpx;
  line-height: 1.35;
}

.page-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
}

.category-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 8rpx;
}

.category-item {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  max-width: 320rpx;
  padding: 18rpx 26rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 999rpx;
  background: #181818;
  color: #b8b8b8;
  font-size: 26rpx;
  line-height: 1.3;
  overflow: hidden;
}

.category-count {
  min-width: 34rpx;
  margin-left: 12rpx;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: inherit;
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
}

.category-item-active {
  border-color: #2f80ed;
  background: #1b3055;
  color: #ffffff;
}

.summary-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  border: 1rpx solid #2a2a2a;
  border-radius: 16rpx;
  background: #161616;
}

.summary-copy {
  flex: 1;
  min-width: 0;
}

.summary-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
}

.summary-desc {
  margin-top: 8rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.6;
}

.summary-phone {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 20rpx;
  max-width: 220rpx;
  padding: 10rpx 14rpx;
  border: 1rpx solid rgba(47, 128, 237, 0.32);
  border-radius: 999rpx;
  color: #d8e6ff;
  font-size: 20rpx;
  line-height: 1.3;
  background: rgba(47, 128, 237, 0.12);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.car-list {
  margin-top: 28rpx;
}

.empty-state {
  margin-top: 40rpx;
  padding: 56rpx 32rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 16rpx;
  background: #181818;
  text-align: center;
}

.empty-title {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.45;
}

.empty-desc {
  margin-top: 14rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.6;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #2a2a2a;
  background: rgba(16, 16, 16, 0.96);
  box-sizing: border-box;
}

.bottom-action {
  flex: 1;
  height: 88rpx;
  margin: 0;
  padding: 0 12rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 14rpx;
  background: #181818;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 88rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.bottom-action-offset {
  margin-left: 16rpx;
}

.bottom-action::after {
  border: 0;
}

.action-contact {
  line-height: 88rpx;
}
