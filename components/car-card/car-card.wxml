<view class="car-card" bindtap="handleTap">
  <image wx:if="{{car.cover}}" class="car-cover" src="{{car.cover}}" mode="aspectFill" />
  <view wx:else class="car-cover car-cover-placeholder">
    <view class="car-cover-placeholder-title">{{car.brand || car.name}}</view>
    <view class="car-cover-placeholder-desc">{{car.coverPlaceholderText || '待上传车辆封面'}}</view>
  </view>
  <view class="car-overlay">
    <view class="car-top">
      <view class="car-nickname">{{car.nickname}}</view>
      <view class="car-status ui-status {{car.statusClass}}">{{car.statusText}}</view>
    </view>

    <view class="car-bottom">
      <view class="car-meta">
        <view class="car-name">{{car.name}}</view>
        <view class="car-tags">
          <text wx:for="{{car.tags}}" wx:key="*this" class="car-tag">{{item}}</text>
        </view>
      </view>
      <view class="car-price">{{car.priceText}}</view>
    </view>
  </view>
</view>
