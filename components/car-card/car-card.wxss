.car-card {
  position: relative;
  height: 400rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  background: #181818;
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.18);
}

.car-cover {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1f1f1f, #0f0f0f);
}

.car-cover-placeholder {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 28rpx;
  background: linear-gradient(135deg, #1f2f45, #0f1620);
  box-sizing: border-box;
}

.car-cover-placeholder-title {
  color: rgba(255, 255, 255, 0.95);
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
}

.car-cover-placeholder-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.5;
}

.car-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 26rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.16), rgba(0, 0, 0, 0.62));
  box-sizing: border-box;
}

.car-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.car-nickname {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.24;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.car-status {
  flex-shrink: 0;
  margin-left: 16rpx;
  max-width: 176rpx;
}

.car-bottom {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.car-meta {
  flex: 1;
  min-width: 0;
}

.car-name {
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.car-tags {
  margin-top: 12rpx;
  overflow: hidden;
}

.car-tag {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
  padding: 8rpx 16rpx;
  max-width: 100%;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 999rpx;
  color: #f2f2f2;
  font-size: 20rpx;
  line-height: 1.3;
  background: rgba(0, 0, 0, 0.22);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.car-price {
  flex-shrink: 0;
  margin-left: 20rpx;
  max-width: 220rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
