<view class="detail-page">
  <view class="header-card ui-card">
    <view class="booking-name">{{booking.vehicleName || "--"}}</view>
    <view class="booking-status ui-status ui-status-lg {{statusClass}}">{{statusText}}</view>
  </view>

  <view class="info-card ui-card">
    <view class="info-row">
      <view class="info-label">预约编号</view>
      <view class="info-value">{{booking.id || "--"}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">联系人</view>
      <view class="info-value">{{booking.userName || "--"}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">手机号</view>
      <view class="info-value">{{booking.phone || "--"}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">预约日期</view>
      <view class="info-value">{{booking.startDate || "--"}} - {{booking.endDate || "--"}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">取车城市</view>
      <view class="info-value">{{booking.city || "--"}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">提交时间</view>
      <view class="info-value">{{createdAtText || "--"}}</view>
    </view>
    <view wx:if="{{updatedAtText}}" class="info-row">
      <view class="info-label">最后更新</view>
      <view class="info-value">{{updatedAtText}}</view>
    </view>
  </view>

  <view wx:if="{{booking.note}}" class="note-card ui-card">
    <view class="note-title">备注</view>
    <view class="note-content">{{booking.note}}</view>
  </view>

  <view wx:if="{{canCancel}}" class="actions">
    <button class="cancel-btn ui-btn ui-btn-danger-ghost" bindtap="handleCancel">取消预约</button>
  </view>
</view>
