.booking-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background: #101010;
  box-sizing: border-box;
}

.booking-card,
.empty-page {
  margin-bottom: 24rpx;
  padding: 30rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 16rpx;
  background: #181818;
  box-sizing: border-box;
}

.section-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.section-desc {
  margin-top: 14rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.65;
  word-break: break-word;
}

.car-card {
  background: linear-gradient(180deg, #1c1c1c, #151515);
}

.car-name {
  margin-top: 18rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.form-item {
  margin-top: 24rpx;
}

.form-label {
  margin-bottom: 12rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.4;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  padding: 22rpx 20rpx;
  border: 1rpx solid #323232;
  border-radius: 14rpx;
  background: #141414;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.form-picker {
  color: #7f7f7f;
}

.form-picker-filled {
  color: #ffffff;
}

.form-textarea {
  min-height: 180rpx;
}

.submit-button {
  width: 100%;
  min-height: 88rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 88rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.submit-button-disabled {
  background: #6f8fbc;
  color: rgba(255, 255, 255, 0.88);
}

.submit-button::after {
  border: 0;
}

.empty-action {
  width: 100%;
  min-height: 84rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 84rpx;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-action::after {
  border: 0;
}

.empty-page {
  margin-top: 48rpx;
  text-align: center;
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.35;
}

.empty-desc {
  margin-top: 16rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-word;
}
