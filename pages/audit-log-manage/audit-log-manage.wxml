<view class="audit-page">
  <view class="header">
    <view class="title">审计日志</view>
    <view class="desc">展示权限分配、运营配置变更等关键操作记录（仅管理员可见）</view>
  </view>

  <view class="filter-card ui-card">
    <input
      class="keyword-input ui-input"
      placeholder="搜索 OpenID / 车辆ID / 预约ID / 字段"
      value="{{keyword}}"
      bindinput="handleKeywordInput"
      confirm-type="search"
      bindconfirm="handleSearch"
    />

    <scroll-view class="action-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
      <view class="action-list">
        <view
          wx:for="{{actionOptions}}"
          wx:key="value"
          class="action-chip ui-pill {{currentAction === item.value ? 'ui-pill-active' : ''}}"
          data-action="{{item.value}}"
          bindtap="handleActionTap"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <view class="actions">
      <button class="action-btn ui-btn ui-btn-primary" bindtap="handleSearch">查询</button>
    </view>

    <view class="result-count">当前筛选结果 {{total}} 条</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:elif="{{list.length}}">
    <view class="log-item ui-card ui-card-soft" wx:for="{{list}}" wx:key="id">
      <view class="log-head">
        <view class="log-action">{{item.action || '--'}}</view>
        <view class="log-time">{{item.createdAtText || '--'}}</view>
      </view>
      <view class="log-openid">操作者：{{item.openid || '--'}}</view>
      <view wx:if="{{item.summary}}" class="log-summary">{{item.summary}}</view>
    </view>

    <view class="load-more">
      <button wx:if="{{hasMore && !loading}}" class="load-more-btn ui-btn ui-btn-ghost" bindtap="handleLoadMore">加载更多</button>
      <view wx:elif="{{!hasMore}}" class="load-more-end">已加载全部</view>
    </view>
  </view>

  <view wx:else class="empty ui-card">
    <view class="empty-title">{{emptyTitle}}</view>
    <view class="empty-desc">{{emptyDesc}}</view>
  </view>
</view>
