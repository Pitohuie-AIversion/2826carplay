<view class="detail-page">
  <view class="header-card ui-card">
    <view class="booking-name">{{booking.vehicleName || "--"}}</view>
    <view class="booking-status ui-status ui-status-lg {{statusClass}}">{{statusText}}</view>
  </view>

  <view class="info-card ui-card">
    <view class="info-grid">
      <view class="info-item">
        <view class="info-label">预约编号</view>
        <view class="info-value">{{booking.id || "--"}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">车辆 ID</view>
        <view class="info-value">{{booking.vehicleId || "--"}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">联系人</view>
        <view class="info-value">{{booking.userName || "--"}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">手机号</view>
        <view class="info-value">{{booking.phone || "--"}}</view>
      </view>
      <view class="info-item info-item-full">
        <view class="info-label">预约日期</view>
        <view class="info-value">{{booking.startDate || "--"}} - {{booking.endDate || "--"}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">取车城市</view>
        <view class="info-value">{{booking.city || "--"}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">提交时间</view>
        <view class="info-value">{{createdAtText || "--"}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">最后更新</view>
        <view class="info-value">{{updatedAtText || "--"}}</view>
      </view>
      <view class="info-item info-item-full">
        <view class="info-label">用户 OpenID</view>
        <view class="info-value">{{booking.openid || "--"}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{booking.note}}" class="note-card ui-card">
    <view class="note-title">用户备注</view>
    <view class="note-content">{{booking.note}}</view>
  </view>

  <view class="note-card ui-card ui-card-soft">
    <view class="note-head">
      <view class="note-title">管理员备注</view>
      <view wx:if="{{adminRemarkUpdatedAtText}}" class="note-time">{{adminRemarkUpdatedAtText}}</view>
    </view>
    <textarea
      class="remark-input"
      maxlength="200"
      placeholder="记录联系结果、到店时间、后续计划"
      value="{{booking.adminRemarkDraft}}"
      bindinput="handleRemarkInput"
    />
    <button class="save-btn ui-btn ui-btn-primary" bindtap="handleSaveRemark">保存备注</button>
  </view>

  <view class="action-card ui-card">
    <view class="action-title">状态操作</view>
    <view class="status-actions">
      <button class="status-btn" data-status="pending" bindtap="handleUpdateStatus">待联系</button>
      <button class="status-btn status-btn-alt" data-status="contacted" bindtap="handleUpdateStatus">已联系</button>
      <button class="status-btn" data-status="completed" bindtap="handleUpdateStatus">已完成</button>
      <button class="status-btn status-btn-alt status-btn-danger status-btn-last" data-status="cancelled" bindtap="handleUpdateStatus">取消</button>
    </view>
  </view>
</view>
