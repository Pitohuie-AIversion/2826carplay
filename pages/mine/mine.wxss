.mine-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  background: #101010;
  box-sizing: border-box;
}

.profile-card,
.section-card {
  margin-bottom: 24rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.profile-card {
  display: flex;
  align-items: center;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #2f80ed;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  margin-right: 24rpx;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.45;
  word-break: break-word;
}

.profile-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 10rpx;
}

.profile-brand-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border: 1rpx solid rgba(47, 128, 237, 0.32);
  border-radius: 999rpx;
  background: rgba(47, 128, 237, 0.12);
  color: #d8e6ff;
  font-size: 20rpx;
  line-height: 1.3;
}

.profile-brand-note {
  margin-left: 12rpx;
  color: #8f98a6;
  font-size: 22rpx;
  line-height: 1.5;
}

.profile-desc,
.section-desc,
.menu-desc {
  margin-top: 10rpx;
  color: #a8a8a8;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.menu-item-last {
  padding-bottom: 0;
  border-bottom: 0;
}

.menu-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.5;
}

.menu-arrow {
  flex-shrink: 0;
  color: #6f7784;
  font-size: 34rpx;
  line-height: 1;
}

.action-button {
  height: 88rpx;
  margin-top: 20rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  line-height: 88rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-button-offset {
  margin-top: 16rpx;
}

.action-button::after {
  border: 0;
}
