.detail-page {
  min-height: 100vh;
  padding-bottom: 196rpx;
  background: #101010;
}

.hero-swiper {
  height: 440rpx;
  background: #181818;
}

.hero-image {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1f1f1f, #0f0f0f);
}

.hero-placeholder {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-end;
  padding: 34rpx 28rpx;
  background: linear-gradient(135deg, #1b2c46, #0f1620);
  box-sizing: border-box;
}

.hero-placeholder-brand {
  color: rgba(255, 255, 255, 0.7);
  font-size: 22rpx;
  line-height: 1.4;
}

.hero-placeholder-name {
  margin-top: 10rpx;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.hero-placeholder-text {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
  line-height: 1.6;
}

.summary-card,
.notice-card,
.info-card,
.empty-page {
  margin: 24rpx;
  padding: 30rpx;
  border: 1rpx solid #3a3a3a;
  border-radius: 16rpx;
  background: #181818;
  box-sizing: border-box;
}

.summary-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.car-name {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.car-nickname {
  margin-top: 10rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.65;
}

.car-status {
  flex-shrink: 0;
  margin-left: 20rpx;
  max-width: 180rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1.3;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-available {
  background: #2f80ed;
}

.status-rented {
  background: #8a8a8a;
}

.status-maintenance {
  background: #f2994a;
}

.status-reserved {
  background: #9b51e0;
}

.car-price {
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.4;
}

.tag-list {
  margin-top: 18rpx;
}

.tag-item {
  display: inline-block;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  padding: 8rpx 16rpx;
  max-width: 100%;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 999rpx;
  color: #f2f2f2;
  font-size: 20rpx;
  line-height: 1.3;
  background: rgba(0, 0, 0, 0.22);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-card {
  border-color: rgba(47, 128, 237, 0.28);
  background: rgba(47, 128, 237, 0.08);
}

.notice-title {
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
}

.notice-text {
  margin-top: 12rpx;
  color: #d8e6ff;
  font-size: 24rpx;
  line-height: 1.7;
}

.section-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.45;
}

.section-text {
  margin-top: 16rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.7;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-top: 20rpx;
}

.info-item {
  width: 48%;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #2d2d2d;
  border-radius: 14rpx;
  background: #151515;
}

.info-label {
  color: #8f8f8f;
  font-size: 22rpx;
  line-height: 1.4;
}

.info-value {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
  word-break: break-all;
}

.detail-bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  padding: 18rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #2a2a2a;
  background: rgba(16, 16, 16, 0.96);
  box-sizing: border-box;
}

.action-button {
  flex: 1;
  height: 88rpx;
  margin: 0;
  padding: 0 14rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  line-height: 88rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.action-button-offset {
  margin-left: 16rpx;
}

.action-button::after {
  border: 0;
}

.action-primary {
  background: #2f80ed;
  color: #ffffff;
}

.action-secondary {
  border: 1rpx solid #3a3a3a;
  background: #181818;
  color: #ffffff;
}

.empty-action {
  height: 88rpx;
  margin-top: 24rpx;
  border-radius: 14rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 88rpx;
}

.empty-action::after {
  border: 0;
}

.empty-page {
  margin-top: 48rpx;
  text-align: center;
}

.empty-title {
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.4;
}

.empty-desc {
  margin-top: 16rpx;
  color: #b8b8b8;
  font-size: 24rpx;
  line-height: 1.6;
}
