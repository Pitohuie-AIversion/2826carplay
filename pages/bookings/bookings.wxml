<view class="bookings-page">
  <view class="page-title">我的预约</view>
  <view class="page-desc">查看已提交的预约咨询，跟踪联系进度与出行日期。</view>

  <view wx:if="{{loading && !list.length}}" class="loading">加载中...</view>

  <view wx:elif="{{loadFailed && !list.length}}" class="empty">
    <view class="empty-title">加载失败</view>
    <view class="empty-desc">{{loadErrorText}}</view>
    <button class="empty-action ui-btn ui-btn-primary" bindtap="handleRetryLoad">重新加载</button>
  </view>

  <view wx:elif="{{list.length}}">
    <view class="booking-item ui-card" wx:for="{{list}}" wx:key="id">
      <view class="booking-main">
        <view class="booking-name">{{item.vehicleName}}</view>
        <view class="booking-status ui-status ui-status-lg {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="booking-sub">
        <view class="booking-meta-chip">日期 {{item.startDate}} - {{item.endDate}}</view>
        <view class="booking-meta-chip booking-meta-chip-weak">城市 {{item.city}}</view>
      </view>
      <view wx:if="{{item.note}}" class="booking-note-box">
        <view class="booking-note-label">用户备注</view>
        <view class="booking-note">{{item.note}}</view>
      </view>
      <view class="booking-actions">
        <button class="booking-btn ui-btn ui-btn-primary {{item.canCancel ? '' : 'booking-btn-last'}}" data-id="{{item.id}}" bindtap="handleViewDetail">查看详情</button>
        <button
          wx:if="{{item.canCancel}}"
          class="booking-btn ui-btn ui-btn-danger-ghost booking-btn-last"
          data-id="{{item.id}}"
          bindtap="handleCancel"
        >
          取消预约
        </button>
      </view>
    </view>

    <button wx:if="{{hasMore}}" class="empty-action ui-btn ui-btn-ghost" loading="{{loading}}" bindtap="handleLoadMore">加载更多</button>
  </view>

  <view wx:else class="empty">
    <view class="empty-title">暂无预约</view>
    <view class="empty-desc">去车库挑一辆喜欢的车，提交预约咨询吧。</view>
    <button class="empty-action ui-btn ui-btn-primary" bindtap="handleBackGarage">返回车库</button>
  </view>
</view>
