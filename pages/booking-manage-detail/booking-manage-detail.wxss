.detail-page {
  padding: 24rpx 24rpx 48rpx;
  box-sizing: border-box;
  color: #ffffff;
  background: #101010;
}

.header-card,
.info-card,
.note-card,
.action-card {
  padding: 26rpx 24rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
}

.booking-name {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-word;
}

.booking-status {
  display: inline-block;
  margin-top: 14rpx;
  max-width: 220rpx;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 2rpx -6rpx 0;
}

.info-item {
  width: calc(50% - 12rpx);
  margin: 0 6rpx 12rpx;
  padding: 20rpx 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  box-sizing: border-box;
}

.info-item-full {
  width: calc(100% - 12rpx);
}

.info-label {
  font-size: 22rpx;
  color: #8f98a6;
  margin-bottom: 8rpx;
  line-height: 1.45;
}

.info-value {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  word-break: break-all;
}

.note-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.note-title,
.action-title {
  font-size: 22rpx;
  color: #8f98a6;
  margin-bottom: 12rpx;
}

.note-time {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 16rpx;
  max-width: 45%;
  line-height: 1.4;
  text-align: right;
  word-break: break-word;
}

.note-head .note-title {
  flex: 1;
  min-width: 0;
  line-height: 1.4;
  word-break: break-word;
}

.note-content {
  font-size: 24rpx;
  line-height: 1.65;
  word-break: break-word;
}

.remark-input {
  width: 100%;
  min-height: 180rpx;
  margin-top: 10rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.6;
}

.save-btn {
  width: 100%;
  margin-top: 14rpx;
  box-sizing: border-box;
}

.status-actions {
  display: flex;
  flex-wrap: wrap;
  margin-top: 2rpx;
}

.status-btn {
  width: 48%;
  margin-right: 4%;
  margin-bottom: 16rpx;
  height: 72rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  background: #141414;
  color: #ffffff;
  box-sizing: border-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.status-btn::after {
  border: 0;
}

.status-btn-alt {
  margin-right: 0;
}

.status-btn-danger {
  border-color: rgba(214, 75, 75, 0.6);
  background: rgba(214, 75, 75, 0.12);
}

.status-btn-last {
  margin-right: 0;
}
