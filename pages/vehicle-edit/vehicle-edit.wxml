<view class="vehicle-edit-page">
  <view class="hero-card">
    <view class="hero-title">编辑车辆</view>
    <view class="hero-desc">修改车辆基础信息并保存到云数据库，也可进入图片管理维护车辆封面与相册。</view>
  </view>

  <view class="loading-card" wx:if="{{loading}}">
    <view class="loading-text">车辆信息加载中...</view>
  </view>

  <view wx:else>
    <view class="form-card">
      <view class="field-group">
        <view class="field-label">车牌号</view>
        <input
          class="field-input"
          placeholder="例如：京A12345"
          value="{{form.plateNumber}}"
          maxlength="8"
          bindinput="handlePlateInput"
        />
      </view>

      <view class="field-group">
        <view class="field-label">车辆类型</view>
        <picker range="{{vehicleTypeLabels}}" value="{{vehicleTypeIndex}}" bindchange="handleVehicleTypeChange">
          <view class="picker-field {{form.vehicleType ? '' : 'picker-field-placeholder'}}">
            {{vehicleTypeLabel || "请选择车辆类型"}}
          </view>
        </picker>
      </view>

      <view class="field-group">
        <view class="field-label">品牌型号</view>
        <input
          class="field-input"
          placeholder="例如：BMW 740Li"
          value="{{form.brandModel}}"
          maxlength="50"
          data-field="brandModel"
          bindinput="handleTextInput"
        />
      </view>

      <view class="field-group">
        <view class="field-label">注册日期</view>
        <picker mode="date" end="{{today}}" value="{{form.registerDate}}" bindchange="handleDateChange">
          <view class="picker-field {{form.registerDate ? '' : 'picker-field-placeholder'}}">
            {{form.registerDate || "请选择注册日期"}}
          </view>
        </picker>
      </view>

      <view class="field-group field-group-last">
        <view class="field-label">使用状态</view>
        <picker range="{{statusLabels}}" value="{{statusIndex}}" bindchange="handleStatusChange">
          <view class="picker-field {{form.status ? '' : 'picker-field-placeholder'}}">
            {{statusLabel || "请选择使用状态"}}
          </view>
        </picker>
      </view>
    </view>

      <view class="field-group">
        <view class="field-label">取车城市</view>
        <input class="field-input" placeholder="例如：杭州" value="{{form.location}}" maxlength="20" data-field="location" bindinput="handleTextInput" />
      </view>

      <view class="field-group">
        <view class="field-label">日租金</view>
        <input class="field-input" type="number" placeholder="例如：699" value="{{form.priceDay}}" maxlength="5" data-field="priceDay" bindinput="handleTextInput" />
      </view>

      <view class="field-group">
        <view class="field-label">变速箱</view>
        <picker range="{{transmissionLabels}}" value="{{transmissionIndex}}" bindchange="handleTransmissionChange">
          <view class="picker-field {{form.transmission ? '' : 'picker-field-placeholder'}}">
            {{transmissionLabel || "请选择变速箱"}}
          </view>
        </picker>
      </view>

      <view class="field-group">
        <view class="field-label">燃油类型</view>
        <picker range="{{fuelTypeLabels}}" value="{{fuelTypeIndex}}" bindchange="handleFuelTypeChange">
          <view class="picker-field {{form.fuelType ? '' : 'picker-field-placeholder'}}">
            {{fuelTypeLabel || "请选择燃油类型"}}
          </view>
        </picker>
      </view>

      <view class="field-group">
        <view class="field-label">座位数</view>
        <input class="field-input" type="number" placeholder="例如：5" value="{{form.seats}}" maxlength="1" data-field="seats" bindinput="handleTextInput" />
      </view>

      <view class="field-group">
        <view class="field-label">VIN</view>
        <input class="field-input" placeholder="可选，最多 32 位" value="{{form.vin}}" maxlength="32" data-field="vin" bindinput="handleTextInput" />
      </view>

      <view class="field-group">
        <view class="field-label">发动机号</view>
        <input class="field-input" placeholder="可选，最多 32 位" value="{{form.engineNumber}}" maxlength="32" data-field="engineNumber" bindinput="handleTextInput" />
      </view>

      <view class="field-group">
        <view class="field-label">备注说明</view>
        <textarea
          class="field-textarea"
          placeholder="可填写车辆亮点、租赁提示等说明"
          value="{{form.note}}"
          maxlength="200"
          data-field="note"
          bindinput="handleTextInput"
        />
      </view>


    <view class="action-row">
      <button class="secondary-button" bindtap="handleManageImages" disabled="{{loading || isSubmitting}}">
        管理图片
      </button>
      <button class="submit-button" bindtap="handleSubmit" loading="{{isSubmitting}}" disabled="{{isSubmitting}}">
        {{isSubmitting ? "保存中" : "保存修改"}}
      </button>
    </view>
  </view>
</view>
