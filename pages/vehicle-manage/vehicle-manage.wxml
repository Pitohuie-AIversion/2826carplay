<view class="vehicle-manage-page">
  <view class="hero-card">
    <view class="hero-title">车辆管理</view>
    <view class="hero-desc">查看已录入车辆，支持按状态和关键词筛选。</view>
    <button class="hero-button" bindtap="handleGoCreate">新增车辆</button>
  </view>

  <view class="section-card">
    <view class="search-row">
      <input
        class="search-input"
        placeholder="搜索车牌号 / 品牌型号"
        value="{{keyword}}"
        bindinput="handleKeywordInput"
        bindconfirm="handleKeywordConfirm"
        confirm-type="search"
      />
      <button class="search-button" bindtap="handleKeywordConfirm">查询</button>
    </view>

    <scroll-view class="status-scroll" scroll-x enable-flex show-scrollbar="{{false}}">
      <view class="status-list">
        <view
          wx:for="{{statusOptions}}"
          wx:key="value"
          class="status-item {{currentStatus === item.value ? 'status-item-active' : ''}}"
          data-status="{{item.value}}"
          bindtap="handleStatusTap"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>

    <view class="action-row">
      <view class="result-count">共 {{total}} 条记录</view>
      <button class="reset-button" bindtap="handleReset">重置筛选</button>
    </view>
  </view>

  <view class="summary-grid">
    <view wx:for="{{summaryItems}}" wx:key="key" class="summary-item">
      <view class="summary-value">{{item.value}}</view>
      <view class="summary-label">{{item.label}}</view>
    </view>
  </view>

  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-text">车辆数据加载中...</view>
  </view>

  <view class="vehicle-list" wx:elif="{{list.length}}">
    <view wx:for="{{list}}" wx:key="id" class="vehicle-card">
      <view class="vehicle-card-top">
        <view class="vehicle-cover-wrap" data-id="{{item.id}}" bindtap="handleViewDetail">
          <image wx:if="{{item.coverImage}}" class="vehicle-cover" src="{{item.coverImage}}" mode="aspectFill" />
          <view wx:else class="vehicle-cover vehicle-cover-placeholder">
            <view class="vehicle-cover-placeholder-text">暂无图片</view>
          </view>
          <view class="image-count-badge">共 {{item.imageCount || 0}} 张</view>
        </view>

        <view class="vehicle-main">
          <view class="vehicle-card-head">
            <view>
              <view class="plate-number">{{item.plateNumber}}</view>
              <view class="brand-model">{{item.brandModel}}</view>
            </view>
            <view class="vehicle-status {{item.statusClass}}">{{item.statusText}}</view>
          </view>

          <view class="vehicle-meta-grid">
            <view class="meta-item">
              <view class="meta-label">车辆类型</view>
              <view class="meta-value">{{item.vehicleTypeText}}</view>
            </view>
            <view class="meta-item">
              <view class="meta-label">注册日期</view>
              <view class="meta-value">{{item.registerDate}}</view>
            </view>
            <view class="meta-item">
              <view class="meta-label">更新时间</view>
              <view class="meta-value">{{item.updatedAtText || "--"}}</view>
            </view>
            <view class="meta-item">
              <view class="meta-label">创建人</view>
              <view class="meta-value meta-value-ellipsis">{{item.createdByOpenid || "--"}}</view>
            </view>
          </view>
        </view>
      </view>

      <view class="card-action-row">
        <button class="detail-button" data-id="{{item.id}}" bindtap="handleViewDetail">查看详情</button>
        <button class="edit-button" data-id="{{item.id}}" bindtap="handleEdit">编辑车辆</button>
        <button
          wx:if="{{item.status !== 'retired'}}"
          class="retire-button"
          data-id="{{item.id}}"
          data-plate-number="{{item.plateNumber}}"
          bindtap="handleRetire"
        >
          停用车辆
        </button>
        <button
          wx:else
          class="restore-button"
          data-id="{{item.id}}"
          data-plate-number="{{item.plateNumber}}"
          bindtap="handleRestore"
        >
          恢复启用
        </button>
        <button class="delete-button" data-id="{{item.id}}" data-plate-number="{{item.plateNumber}}" bindtap="handleDelete">
          删除车辆
        </button>
      </view>
    </view>
  </view>

  <view class="empty-card" wx:else>
    <view class="empty-title">{{emptyTitle}}</view>
    <view class="empty-desc">{{emptyDesc}}</view>
  </view>
</view>
