.error-page {
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
  color: #ffffff;
  min-height: 100vh;
  background: #101010;
}

.header {
  margin-bottom: 18rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
}

.desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
  line-height: 1.6;
  word-break: break-word;
}

.filter-card {
  margin-bottom: 18rpx;
}

.keyword-input {
  width: 100%;
  height: 78rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
}

.func-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.func-list {
  display: flex;
  align-items: center;
}

.func-chip {
  margin-right: 16rpx;
  padding: 14rpx 24rpx;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.actions {
  margin-top: 14rpx;
}

.action-btn {
  width: 100%;
}

.result-count {
  margin-top: 16rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.72);
}

.loading {
  padding: 40rpx 0;
  text-align: center;
  color: rgba(255, 255, 255, 0.72);
}

.log-item {
  margin-bottom: 16rpx;
}

.log-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.log-func {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
}

.log-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  line-height: 1.4;
  margin-left: 16rpx;
  max-width: 45%;
  text-align: right;
  word-break: break-word;
}

.log-message {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.82);
  word-break: break-word;
}

.log-summary {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.68);
  white-space: pre-wrap;
  word-break: break-word;
}

.copy-btn {
  margin-top: 14rpx;
  width: 100%;
}

.load-more {
  padding: 10rpx 0 0;
  text-align: center;
}

.load-more-btn {
  width: 100%;
  margin: 0;
}

.load-more-end {
  padding: 20rpx 0 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.6);
}

.empty {
  padding: 70rpx 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  color: #ffffff;
  line-height: 1.35;
}

.empty-desc {
  font-size: 24rpx;
  line-height: 1.6;
  word-break: break-word;
  color: rgba(255, 255, 255, 0.72);
}

