<view class="vehicle-create-page">
  <view class="card header-card">
    <view class="page-title">新增车辆</view>
    <view class="page-desc">请按实际车辆信息填写，提交后可直接进入图片管理继续上传车辆图片。</view>
  </view>

  <view class="card tip-card">
    <view class="tip-title">图片上传说明</view>
    <view class="tip-desc">车辆创建成功后，可立即进入详情页上传图片、设置封面并管理已上传素材。</view>
  </view>

  <view class="card form-card">
    <view class="form-item">
      <view class="form-label">车牌号</view>
      <input
        class="form-input"
        placeholder="例如 京A12345 / 粤BDF1234"
        value="{{form.plateNumber}}"
        maxlength="8"
        bindinput="handlePlateInput"
      />
    </view>

    <view class="form-item">
      <view class="form-label">车辆类型</view>
      <picker mode="selector" range="{{vehicleTypeLabels}}" value="{{vehicleTypeIndex}}" bindchange="handleVehicleTypeChange">
        <view class="form-picker {{form.vehicleType ? 'form-picker-filled' : ''}}">
          {{vehicleTypeLabel || '请选择车辆类型'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">品牌型号</view>
      <input
        class="form-input"
        placeholder="例如 BMW 740Li"
        value="{{form.brandModel}}"
        maxlength="50"
        data-field="brandModel"
        bindinput="handleTextInput"
      />
    </view>

    <view class="form-item">
      <view class="form-label">注册日期</view>
      <picker mode="date" value="{{form.registerDate}}" end="{{today}}" bindchange="handleDateChange">
        <view class="form-picker {{form.registerDate ? 'form-picker-filled' : ''}}">
          {{form.registerDate || '请选择注册日期'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">使用状态</view>
      <picker mode="selector" range="{{statusLabels}}" value="{{statusIndex}}" bindchange="handleStatusChange">
        <view class="form-picker {{form.status ? 'form-picker-filled' : ''}}">
          {{statusLabel || '请选择使用状态'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">取车城市</view>
      <input class="form-input" placeholder="例如 杭州" value="{{form.location}}" maxlength="20" data-field="location" bindinput="handleTextInput" />
    </view>

    <view class="form-item">
      <view class="form-label">日租金</view>
      <input class="form-input" type="number" placeholder="例如 699" value="{{form.priceDay}}" maxlength="5" data-field="priceDay" bindinput="handleTextInput" />
    </view>

    <view class="form-item">
      <view class="form-label">变速箱</view>
      <picker mode="selector" range="{{transmissionLabels}}" value="{{transmissionIndex}}" bindchange="handleTransmissionChange">
        <view class="form-picker {{form.transmission ? 'form-picker-filled' : ''}}">
          {{transmissionLabel || '请选择变速箱'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">燃油类型</view>
      <picker mode="selector" range="{{fuelTypeLabels}}" value="{{fuelTypeIndex}}" bindchange="handleFuelTypeChange">
        <view class="form-picker {{form.fuelType ? 'form-picker-filled' : ''}}">
          {{fuelTypeLabel || '请选择燃油类型'}}
        </view>
      </picker>
    </view>

    <view class="form-item">
      <view class="form-label">座位数</view>
      <input class="form-input" type="number" placeholder="例如 5" value="{{form.seats}}" maxlength="1" data-field="seats" bindinput="handleTextInput" />
    </view>

    <view class="form-item">
      <view class="form-label">VIN</view>
      <input class="form-input" placeholder="可选，最多 32 位" value="{{form.vin}}" maxlength="32" data-field="vin" bindinput="handleTextInput" />
    </view>

    <view class="form-item">
      <view class="form-label">发动机号</view>
      <input class="form-input" placeholder="可选，最多 32 位" value="{{form.engineNumber}}" maxlength="32" data-field="engineNumber" bindinput="handleTextInput" />
    </view>

    <view class="form-item">
      <view class="form-label">备注说明</view>
      <textarea
        class="form-textarea"
        placeholder="可填写车辆亮点、租赁提示等说明"
        value="{{form.note}}"
        maxlength="200"
        data-field="note"
        bindinput="handleTextInput"
      />
    </view>
  </view>

  <button
    class="submit-button {{isSubmitting ? 'submit-button-disabled' : ''}}"
    bindtap="handleSubmit"
    disabled="{{isSubmitting}}"
    loading="{{isSubmitting}}"
  >
    {{isSubmitting ? '提交中' : '提交'}}
  </button>
</view>
